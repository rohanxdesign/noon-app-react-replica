  "components": {
    "ProductCard": {
      "path": "src/components/ui/ProductCard/ProductCard.tsx",
      "description": "Product listing card. Shows product image, tag (bestseller/new/hot/sale), wishlist toggle, ATC button, name, variant, rating, price, discount, and optional deal badge.",
      "props": {
        "product": {
          "type": "Product",
          "required": true,
          "description": "Product data object (id, name, variant, images, sellingPrice, originalPrice, currency, rating, reviewCount, tag, deal, isSponsored)"
        }
      },
      "states": {
        "idle": "ATC not in cart — shows plus button (36×36, white bg, 1.2px supermall-800 border)",
        "inCart": "ATC active — expands to 96×36, supermall-800 bg, shows trash/minus + count + plus"
      },
      "css": "src/components/ui/ProductCard/ProductCard.css",
      "notes": "Card height is determined by the taller card in a two-column grid row. Aspect ratio of image wrap is 133/179. Border is #f9f9fb."
    },
    "AddToCart": {
      "path": "src/components/ui/AddToCart/AddToCart.tsx",
      "description": "Animated add-to-cart control. Idles as a 36×36 plus button; expands to 96×36 stepper with trash/minus, count, and plus when quantity > 0.",
      "props": {
        "count": { "type": "number", "required": true, "description": "Current cart quantity for this item" },
        "onAdd": { "type": "() => void", "required": true },
        "onRemove": { "type": "() => void", "required": true }
      },
      "css": "src/components/ui/AddToCart/AddToCart.css"
    },
    "CategoryTabs": {
      "path": "src/pages/PLP/components/CategoryTabs.tsx",
      "description": "Horizontally scrollable category tab strip. Each tab is 74px wide with a 48×48 image and 2-line label. Active tab gets a vertical gradient background and bordered image wrap.",
      "props": {
        "categories": { "type": "Category[]", "required": true },
        "activeId": { "type": "string", "required": true },
        "onSelect": { "type": "(id: string) => void", "required": true }
      },
      "states": {
        "inactive": "Grey-700 label, color-surface-secondary image bg, subtle inset shadow",
        "active": "Supermall-800 label (600 weight), white image bg, supermall-400 border, linear-gradient(180deg, rgb(224,224,255) 0%, transparent 100%) item bg"
      },
      "css": "src/pages/PLP/components/CategoryTabs.css"
    },
    "FilterBar": {
      "path": "src/pages/PLP/components/FilterBar.tsx",
      "description": "Horizontally scrollable filter/sort chip bar. Chips: Filter (filter icon), Sort (sort icon), Brand (chevron), Type (chevron).",
      "props": {
        "activeFilters": { "type": "string[]", "required": false, "default": "[]" },
        "onChipClick": { "type": "(id: string) => void", "required": false }
      },
      "css": "src/pages/PLP/components/FilterBar.css"
    },
    "PLPHeader": {
      "path": "src/pages/PLP/components/PLPHeader.tsx",
      "description": "Page header for PLP. Back chevron on left, title centred, search icon on right.",
      "props": {
        "title": { "type": "string", "required": true }
      },
      "css": "src/pages/PLP/components/PLPHeader.css"
    },
    "BottomNav": {
      "path": "src/components/layout/BottomNav.tsx",
      "description": "Fixed bottom navigation bar with 5 slots: Home, Categories, Supermall logo (centre), Account, Cart. Active state uses supermall-800 icon colour. Cart shows badge when itemCount > 0.",
      "props": {},
      "css": "src/components/layout/BottomNav.css"
    },
    "PLPPage": {
      "path": "src/pages/PLP/index.tsx",
      "description": "Product listing page. Composes PLPHeader, CategoryTabs, FilterBar, and a 2-column ProductCard grid with stagger animation.",
      "props": {},
      "css": "src/pages/PLP/PLP.css",
      "notes": "Background is white (--colour-neutral-white). Grid uses CSS Grid 2 columns with equal row heights via flex stretch."
    }
  }
